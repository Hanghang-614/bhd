{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __BHD_MEMORY_PLUGIN_ROOT__/scripts/bhd_hook.py recall",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __BHD_MEMORY_PLUGIN_ROOT__/scripts/bhd_hook.py capture",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __BHD_MEMORY_PLUGIN_ROOT__/scripts/bhd_hook.py commit",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __BHD_MEMORY_PLUGIN_ROOT__/scripts/bhd_hook.py sweep",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
